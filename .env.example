# Required: path to the cell embedding parquet file
CELL_SEARCH_DATA_PATH=/absolute/path/to/microns_SomaData_AllCells_v661.parquet

# Recommended for neuroglancer and CAVE-backed lookups
CAVE_TOKEN=replace-with-your-token

# Optional runtime settings
CELL_SEARCH_DATASTACK=minnie65_public
CAVE_SERVER_ADDRESS=https://global.daf-apis.com
CELL_SEARCH_HOST=0.0.0.0
CELL_SEARCH_PORT=8050

# Local troubleshooting only. Do not enable in shared deployments.
AUTH_DISABLED=false
